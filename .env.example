# ── PatentSale environment configuration ──────────────────────────────────────
# Copy this file to `.env` and fill in real values for your environment.
# NEVER commit your real `.env` (it is gitignored).

# Database ───────────────────────────────────────────────────────────────────
# LOCAL DEV (SQLite): a relative file path works on any OS.
DATABASE_URL="file:./db/custom.db"

# PRODUCTION (Neon serverless Postgres) ───────────────────────────────────────
# Use the POOLER hostname for the runtime app connection (connection pooling),
# and the DIRECT (non-pooled) hostname for Prisma CLI migrations. This split is
# REQUIRED for Prisma + Neon to work correctly.
# DATABASE_URL=postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require
# DIRECT_URL=postgres://user:pass@ep-xxx.region.aws.neon.tech/db?sslmode=require
# (Update prisma/schema.prisma datasource to provider = "postgresql" for prod.)

# Auth (NextAuth) ─────────────────────────────────────────────────────────────
# Generate a long random string: `openssl rand -base64 32` (Mac/Linux)
# or use any random string generator.
NEXTAUTH_SECRET=change-me-to-a-long-random-string
# Leave NEXTAUTH_URL unset to auto-detect (works on localhost and proxies).
# Set it only if you have a fixed canonical URL in production:
# NEXTAUTH_URL=http://localhost:3000

# Seeded admin (created by `npx tsx prisma/seed.ts`) ─────────────────────────
# Used to bootstrap the first super_admin. Change before any real deployment.
ADMIN_EMAIL=admin@patentforsale.in
ADMIN_PASSWORD=PatentSale123!
# Optional: pin the admin's TOTP secret (otherwise generated at seed time).
# ADMIN_MFA_SECRET=

# Transactional email ─────────────────────────────────────────────────────────
# Provider decision: Resend (or AWS SES / Postmark). When a provider API key is
# present, emails dispatch via the provider; otherwise every email is captured
# to the EmailLog table + console (dev fallback) so flows are observable.
# RESEND_API_KEY=re_xxx
SALES_EMAIL=info@patentforsale.in
FROM_EMAIL=noreply@patentforsale.in

# Object storage (Cloudflare R2 or any S3-compatible) ─────────────────────────
# REQUIRED in production: Railway ephemeral storage does not persist across
# redeploys, so no file the platform must keep is ever written to local disk.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=patentsale
